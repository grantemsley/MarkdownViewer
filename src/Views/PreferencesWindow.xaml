<ui:FluentWindow x:Class="MarkdownViewer.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Preferences"
        Width="460" Height="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="RowPanel" TargetType="DockPanel">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="LastChildFill" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Preferences"/>

        <ScrollViewer Grid.Row="1" Padding="20,8,20,8">
            <StackPanel>
                <TextBlock Text="APPEARANCE" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Theme" Width="160" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ThemeBox" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Follow system" Tag="system"/>
                        <ComboBoxItem Content="Light" Tag="light"/>
                        <ComboBoxItem Content="Dark" Tag="dark"/>
                    </ComboBox>
                </DockPanel>

                <TextBlock Text="FILES" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Show .md extension" Width="280" VerticalAlignment="Center"
                               ToolTip="Non-markdown files always show their extension."/>
                    <ui:ToggleSwitch x:Name="ShowExtensions" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Show all files (not just .md and .jsonl)" Width="280" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch x:Name="ShowNonMarkdown" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Show hidden files (.gitignore, etc.)" Width="280" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch x:Name="ShowHidden" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Wrap long names in sidebar" Width="280" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch x:Name="WrapSidebar" HorizontalAlignment="Right"/>
                </DockPanel>
                <TextBlock Text="SORTING" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Folders" Width="90" VerticalAlignment="Center"/>
                    <ComboBox x:Name="FolderSortDirBox" Width="140" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <ComboBoxItem Content="Ascending" Tag="asc"/>
                        <ComboBoxItem Content="Descending" Tag="desc"/>
                    </ComboBox>
                    <ComboBox x:Name="FolderSortKeyBox" Width="150" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Name" Tag="name"/>
                        <ComboBoxItem Content="Created date" Tag="created"/>
                        <ComboBoxItem Content="Modified date" Tag="modified"/>
                        <ComboBoxItem Content="Extension" Tag="extension"/>
                    </ComboBox>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Files" Width="90" VerticalAlignment="Center"/>
                    <ComboBox x:Name="FileSortDirBox" Width="140" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <ComboBoxItem Content="Ascending" Tag="asc"/>
                        <ComboBoxItem Content="Descending" Tag="desc"/>
                    </ComboBox>
                    <ComboBox x:Name="FileSortKeyBox" Width="150" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Name" Tag="name"/>
                        <ComboBoxItem Content="Created date" Tag="created"/>
                        <ComboBoxItem Content="Modified date" Tag="modified"/>
                        <ComboBoxItem Content="Extension" Tag="extension"/>
                    </ComboBox>
                </DockPanel>

                <TextBlock Text="READING" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Show line numbers" Width="280" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch x:Name="ShowLineNumbers" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Highlight custom tags (&lt;example&gt;, etc.)" Width="280" VerticalAlignment="Center"
                               ToolTip="Shows non-standard HTML tags as labelled chips so the wrapper is visible. Off drops the tags and shows just the content."/>
                    <ui:ToggleSwitch x:Name="HighlightCustomTags" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Body style" Width="160" VerticalAlignment="Center"/>
                    <ComboBox x:Name="BodyStyleBox" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Win11 (default)" Tag="win11"/>
                        <ComboBoxItem Content="GitHub" Tag="github"/>
                    </ComboBox>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Typeface" Width="160" VerticalAlignment="Center"/>
                    <ComboBox x:Name="TypefaceBox" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="System" Tag="system"/>
                        <ComboBoxItem Content="Sans (Inter)" Tag="sans"/>
                        <ComboBoxItem Content="Serif (Charter)" Tag="serif"/>
                        <ComboBoxItem Content="Monospace" Tag="mono"/>
                    </ComboBox>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Font size" Width="160" VerticalAlignment="Center"/>
                    <ui:NumberBox x:Name="FontSizeBox" Width="120" HorizontalAlignment="Left"
                                  Minimum="11" Maximum="22" Value="14"
                                  SpinButtonPlacementMode="Inline"
                                  ClearButtonEnabled="False"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Margins" Width="160" VerticalAlignment="Center"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="MarginsSlider" Grid.Column="0" Minimum="50" Maximum="100"
                                VerticalAlignment="Center"
                                ValueChanged="MarginsChanged"/>
                        <TextBlock x:Name="MarginsReadout" Grid.Column="1" Width="44"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>
                </DockPanel>

                <TextBlock Text="OUTLINE" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Auto-collapse below" Width="160" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CollapseBelowBox" Width="120" HorizontalAlignment="Left">
                        <ComboBoxItem Content="H1" Tag="1"/>
                        <ComboBoxItem Content="H2" Tag="2"/>
                        <ComboBoxItem Content="H3" Tag="3"/>
                        <ComboBoxItem Content="H4" Tag="4"/>
                        <ComboBoxItem Content="H5" Tag="5"/>
                        <ComboBoxItem Content="H6" Tag="6"/>
                        <ComboBoxItem Content="Never" Tag="7"/>
                    </ComboBox>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Always collapse containing" Width="160" VerticalAlignment="Center"/>
                    <ui:TextBox x:Name="CollapseContainingBox" Width="220" HorizontalAlignment="Left"/>
                </DockPanel>

                <TextBlock Text="TABS &amp; WINDOW" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Use tabs (restart to apply)" Width="280" VerticalAlignment="Center"
                               ToolTip="Show a tab strip — each tab has its own folder and open file. Off = single pane, like before."/>
                    <ui:ToggleSwitch x:Name="UseTabsToggle" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Reuse one window — single instance (restart to apply)" Width="280"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               ToolTip="A second launch (e.g. double-clicking a file) opens in the already-running window instead of starting a new process."/>
                    <ui:ToggleSwitch x:Name="SingleInstanceToggle" HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Open files from outside in a new tab" Width="280"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               ToolTip="When a file is opened into the window (with single instance on), open it in a new tab; off replaces the current tab. Only applies with tabs on."/>
                    <ui:ToggleSwitch x:Name="IncomingNewTabToggle" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock Text="UPDATES" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Check for updates on startup" Width="280" VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               ToolTip="Checks GitHub Releases once at launch and shows a banner if a newer version exists. Nothing is sent or installed automatically."/>
                    <ui:ToggleSwitch x:Name="CheckUpdatesToggle" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock Text="WINDOWS INTEGRATION" Style="{StaticResource SectionLabel}"/>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Open .md and .jsonl files with MarkdownViewer" Width="280" VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               ToolTip="Adds MarkdownViewer to the Open-with list and registers its icon (per-user, no admin)."/>
                    <ui:ToggleSwitch x:Name="FileAssocToggle" HorizontalAlignment="Right" Click="FileAssocToggle_Click"/>
                </DockPanel>
                <DockPanel Style="{StaticResource RowPanel}">
                    <TextBlock Text="Add &quot;Open in MarkdownViewer&quot; to the folder right-click menu" Width="280"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               ToolTip="On Windows 11 this appears under &quot;Show more options.&quot;"/>
                    <ui:ToggleSwitch x:Name="ContextMenuToggle" HorizontalAlignment="Right" Click="ContextMenuToggle_Click"/>
                </DockPanel>
                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Applies to your user account only. To make MarkdownViewer the default for a type, right-click a file → Open with → Choose another app → tick &quot;Always.&quot;"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Done" MinWidth="90" IsDefault="True"
                           Appearance="Primary" Click="Done_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
