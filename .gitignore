# Append these to your project's .gitignore. Safe to add even if some
# are already present — duplicates are ignored.

# Claude Code tooling: settings, skills, and session transcripts.
# Kept on disk for local development; never published.
.claude/

# Local Claude project instructions (personal/environment context).
# Stays on disk so sessions still load it; not committed.
CLAUDE.md
CLAUDE.local.md

# Legacy migration archive (session notes, old plans) — not published.
old/

# Credentials and sensitive files (defensive).
**/*api*key*
**/*.env

# Python
__pycache__/
*.pyc

# .NET build artifacts
[Bb]in/
[Oo]bj/

# Publish output (build artifact)
publish/

# Per-bucket MCP config (kept local — public repo).
.mcp.json

# Auto-managed session notes (rewritten by the summarize-notes curator).
notes.md

# Live curated notes (branch-independent; promoted to .claude/notes.md on main).
.claude/notes.md
.claude/history.md
.claude/notes.archive.md
